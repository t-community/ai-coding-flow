# ── Platform ──────────────────────────────────────────────────────────────────
PLATFORM=github
REPO_URL=https://github.com/t-community/demo-repository
GITHUB_TOKEN=ghp_...
GITLAB_TOKEN=
WEBHOOK_SECRET=your-webhook-secret
# true = log all workflow steps in detail
VERBOSE=true
# false = skip SSL verification when cloning repos (self-signed certs)
VERIFY_REPO_SSL=false
# false = skip SSL verification when connecting to LLM endpoint (self-signed certs)
VERIFY_ENGINE_SSL=false

# ── LLM endpoint ──────────────────────────────────────────────────────────────
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-oss-120b:free

# ── Workflow ───────────────────────────────────────────────────────────────────
# aider | opencode | claudecode — override per-issue with label "agent: opencode"
DEFAULT_AGENT=opencode
MAX_RETRIES=3
# empty = skip tests; examples: pytest / npm test / go test ./...
TEST_CMD=
# seconds before an engine subprocess is killed
AGENT_TIMEOUT=600

# ── Aider settings ────────────────────────────────────────────────────────────
# AIDER_VERBOSE=false  (deprecated — use VERBOSE instead)
# tokens allocated to the repo map
AIDER_MAP_TOKENS=2048
# max tokens of non-code files pre-loaded via --file
AIDER_TOKEN_BUDGET=80000

# ── OpenCode settings ─────────────────────────────────────────────────────────
# model context window advertised to opencode
OPENCODE_CONTEXT_LIMIT=32768
# max output tokens advertised to opencode
OPENCODE_OUTPUT_LIMIT=4096

# ── Claude Code settings ──────────────────────────────────────────────────────
# port the ccr router listens on
CLAUDECODE_ROUTER_PORT=3456
# seconds to wait for ccr to start
CLAUDECODE_ROUTER_STARTUP_TIMEOUT=15

# ── Server ────────────────────────────────────────────────────────────────────
# optional — protects /api/jobs if set
ADMIN_PASSWORD=
