# ── Platform ──────────────────────────────────────────────────────────────────
PLATFORM=github
REPO_URL=https://github.com/t-community/demo-repository
GITHUB_TOKEN=ghp_...
GITLAB_TOKEN=
WEBHOOK_SECRET=your-webhook-secret
VERBOSE=true                                 # true = log all workflow steps in detail
VERIFY_REPO_SSL=false                                  # false = skip SSL verification when cloning repos (self-signed certs)
VERIFY_ENGINE_SSL=false                                  # false = skip SSL verification when connecting to LLM endpoint (self-signed certs)

# ── LLM endpoint ──────────────────────────────────────────────────────────────
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-oss-120b:free

# ── Workflow ───────────────────────────────────────────────────────────────────
DEFAULT_AGENT=opencode                    # aider | opencode | claudecode
                                       # override per-issue with label "agent: opencode"
MAX_RETRIES=3
# empty = skip tests; examples: pytest / npm test / go test ./...
TEST_CMD=
AGENT_TIMEOUT=600                      # seconds before an engine subprocess is killed

# ── Aider settings ────────────────────────────────────────────────────────────
# AIDER_VERBOSE=false                    # true = log full aider output (deprecated)
AIDER_MAP_TOKENS=2048                  # tokens allocated to the repo map
AIDER_TOKEN_BUDGET=80000              # max tokens of non-code files pre-loaded via --file
# AIDER_VERIFY_SSL=true                  # false = pass --no-verify-ssl (deprecated)

# ── OpenCode settings ─────────────────────────────────────────────────────────
OPENCODE_CONTEXT_LIMIT=32768           # model context window advertised to opencode
OPENCODE_OUTPUT_LIMIT=4096             # max output tokens advertised to opencode

# ── Claude Code settings ──────────────────────────────────────────────────────
CLAUDECODE_ROUTER_PORT=3456            # port the ccr router listens on
CLAUDECODE_ROUTER_STARTUP_TIMEOUT=15   # seconds to wait for ccr to start

# ── Server ────────────────────────────────────────────────────────────────────
# optional — protects /api/jobs if set
ADMIN_PASSWORD=
